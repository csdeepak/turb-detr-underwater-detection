# ============================================================
# .gitignore — Turb-DETR Underwater Plastic Detection
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
*.so

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter / Colab ──────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Datasets (never commit large data) ──────────────────────
data/raw/*
data/processed/*
data/annotations/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/annotations/.gitkeep

# ── Model Outputs & Artifacts ────────────────────────────────
outputs/checkpoints/*
outputs/logs/*
outputs/visualizations/*
!outputs/checkpoints/.gitkeep
!outputs/logs/.gitkeep
!outputs/visualizations/.gitkeep
*.pt
*.pth
*.onnx
*.engine

# ── Experiment Tracking ─────────────────────────────────────
wandb/
runs/
mlruns/

# ── Misc ─────────────────────────────────────────────────────
*.log
*.tar.gz
*.zip
